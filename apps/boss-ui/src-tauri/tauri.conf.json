{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BOSS",
  "version": "0.1.0",
  "identifier": "com.sagau.boss",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run icon && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BOSS",
        "width": 1520,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
